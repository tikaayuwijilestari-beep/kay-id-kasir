---
const url = new URL(Astro.request.url);
const error = url.searchParams.get('error');

const errorMessages: Record<string, string> = {
  not_authorized: 'Email Anda tidak terdaftar. Hanya tikaayuwijilestari@gmail.com yang dapat login.',
  access_denied: 'Login dibatalkan. Silakan coba lagi.',
  no_code: 'Kode otorisasi tidak ditemukan.',
  token_failed: 'Gagal memverifikasi akun Google.',
  oauth_not_configured: 'Google SSO belum dikonfigurasi. Hubungi administrator.',
  missing_fields: 'Nama dan email harus diisi.',
};

const errorMsg = error ? (errorMessages[error] || 'Terjadi kesalahan saat login.') : null;
---
<!doctype html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login - Kay.id</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #1e3a5f 0%, #1a56db 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .login-card {
      background: white;
      border-radius: 1rem;
      padding: 2.5rem;
      width: 100%;
      max-width: 400px;
      box-shadow: 0 25px 50px rgba(0,0,0,0.25);
    }
    .login-card h1 {
      text-align: center;
      font-size: 1.75rem;
      margin-bottom: 0.25rem;
    }
    .login-card h1 span { color: #1a56db; }
    .login-card .subtitle {
      text-align: center;
      color: #6b7280;
      font-size: 0.875rem;
      margin-bottom: 1.5rem;
    }
    .sso-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      width: 100%;
      padding: 0.85rem;
      border: 2px solid #e5e7eb;
      border-radius: 0.75rem;
      background: white;
      font-size: 1rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
      color: #374151;
    }
    .sso-btn:hover { border-color: #1a56db; background: #f0f5ff; }
    .sso-btn svg { width: 22px; height: 22px; }
    .error-msg {
      background: #fee2e2;
      color: #991b1b;
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      font-size: 0.85rem;
      margin-bottom: 1rem;
      text-align: center;
      border: 1px solid #fecaca;
    }
    .footer-text {
      text-align: center;
      margin-top: 1.5rem;
      font-size: 0.75rem;
      color: #9ca3af;
    }
    .info-text {
      text-align: center;
      margin-top: 1rem;
      font-size: 0.8rem;
      color: #6b7280;
      padding: 0.75rem;
      background: #f0f5ff;
      border-radius: 0.5rem;
    }
  </style>
</head>
<body>
  <div class="login-card">
    <h1><span>Kay</span>.id</h1>
    <p class="subtitle">Sistem Kasir Toko Bangunan</p>

    {errorMsg && <div class="error-msg">{errorMsg}</div>}

    <a href="/api/auth/google" class="sso-btn">
      <svg viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
      Login dengan Google SSO
    </a>

    <div class="info-text">
      Hanya akun <strong>tikaayuwijilestari@gmail.com</strong> yang dapat mengakses sistem ini.
    </div>

    <p class="footer-text">Kay.id v1.0 — Toko Bangunan POS System</p>
  </div>
</body>
</html>
