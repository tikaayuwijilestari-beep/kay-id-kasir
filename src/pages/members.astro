---
import Layout from '../layouts/Layout.astro';
import { requireAdmin, OWNER_EMAIL } from '../lib/auth';
import { getDB } from '../lib/db';

const user = await requireAdmin(Astro.request);
if (user instanceof Response) return user;

const db = await getDB(Astro.request);
const members = (await db.prepare('SELECT * FROM users ORDER BY created_at DESC').all()).results as any[];
---

<Layout title="Members" user={user} activePage="/members">
  <div class="page-header">
    <h1>Member Management</h1>
    <button class="btn btn-primary" onclick="document.getElementById('addMemberModal').classList.remove('hidden')">+ Tambah Member</button>
  </div>

  <div class="card">
    <div class="info-text" style="background:#f0f5ff;padding:0.75rem;border-radius:0.5rem;margin-bottom:1rem;font-size:0.85rem;color:#1e40af;">
      Hanya admin (<strong>{OWNER_EMAIL}</strong>) yang dapat menambah atau menghapus member.
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Nama</th><th>Email</th><th>Role</th><th>Login Terakhir</th><th>Dibuat</th><th>Aksi</th></tr>
        </thead>
        <tbody>
          {members.map((m: any) => (
            <tr>
              <td>
                <div class="flex items-center gap-1">
                  <img src={m.avatar_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(m.name)}&background=1a56db&color=fff&size=32`} style="width:32px;height:32px;border-radius:50%;" alt="" />
                  <strong>{m.name}</strong>
                  {m.email === OWNER_EMAIL && <span class="badge badge-info">Owner</span>}
                </div>
              </td>
              <td>{m.email}</td>
              <td><span class={`badge ${m.role === 'admin' ? 'badge-danger' : 'badge-success'}`}>{m.role}</span></td>
              <td>{m.last_login || '-'}</td>
              <td>{m.created_at}</td>
              <td>
                {m.email !== OWNER_EMAIL ? (
                  <form action="/api/members/delete" method="POST" style="display:inline;">
                    <input type="hidden" name="user_id" value={m.id} />
                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Hapus member ini?')">Hapus</button>
                  </form>
                ) : (
                  <span style="color:var(--gray-500);font-size:0.8rem;">Tidak bisa dihapus</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Add Member Modal -->
  <div id="addMemberModal" class="modal-overlay hidden">
    <div class="modal">
      <div class="modal-header">
        <h2>Tambah Member / Kasir</h2>
        <button class="modal-close" onclick="document.getElementById('addMemberModal').classList.add('hidden')">&times;</button>
      </div>
      <form action="/api/members/create" method="POST">
        <div class="form-group">
          <label>Nama Lengkap *</label>
          <input type="text" name="name" class="form-control" required />
        </div>
        <div class="form-group">
          <label>Email *</label>
          <input type="email" name="email" class="form-control" required />
        </div>
        <div class="form-group">
          <label>Role</label>
          <select name="role" class="form-control">
            <option value="kasir">Kasir</option>
            <option value="admin">Admin</option>
          </select>
        </div>
        <div class="flex gap-1" style="justify-content:flex-end;margin-top:1rem;">
          <button type="button" class="btn btn-outline" onclick="document.getElementById('addMemberModal').classList.add('hidden')">Batal</button>
          <button type="submit" class="btn btn-primary">Tambah Member</button>
        </div>
      </form>
    </div>
  </div>
</Layout>
