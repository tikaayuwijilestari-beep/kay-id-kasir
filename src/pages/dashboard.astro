---
import Layout from '../layouts/Layout.astro';
import { requireAuth, formatCurrency } from '../lib/auth';
import { getDB, getEnvFromLocals } from '../lib/db';

const env = getEnvFromLocals(Astro.locals);
const user = await requireAuth(env, Astro.request);
if (user instanceof Response) return user;

const db = await getDB(env);

const stats = await db.prepare(`
  SELECT
    COUNT(*) as total_items,
    SUM(stock_saat_ini) as total_stock,
    SUM(nilai_aset) as total_aset,
    SUM(nilai_barang_terjual) as total_terjual,
    SUM(keuntungan_penjualan) as total_profit,
    SUM(CASE WHEN stock_saat_ini <= batas_stok_min THEN 1 ELSE 0 END) as low_stock,
    COUNT(DISTINCT kategori) as total_kategori
  FROM inventory
`).first() as any;

const todaySales = await db.prepare(`
  SELECT COUNT(*) as cnt, COALESCE(SUM(total), 0) as total,
    COALESCE(SUM(subtotal), 0) as subtotal_val
  FROM sales WHERE tanggal = date('now')
`).first() as any;

const monthSales = await db.prepare(`
  SELECT COUNT(*) as cnt, COALESCE(SUM(total), 0) as total
  FROM sales WHERE strftime('%Y-%m', tanggal) = strftime('%Y-%m', 'now')
`).first() as any;

const todayExpense = await db.prepare(`
  SELECT COALESCE(SUM(r.total_biaya), 0) as total
  FROM restock r WHERE r.tanggal = date('now') AND r.status = 'completed'
`).first() as any;

const recentSales = (await db.prepare(`
  SELECT * FROM sales ORDER BY created_at DESC LIMIT 5
`).all()).results as any[];

const lowStockItems = (await db.prepare(`
  SELECT * FROM inventory WHERE stock_saat_ini <= batas_stok_min ORDER BY stock_saat_ini ASC LIMIT 5
`).all()).results as any[];

const topProducts = (await db.prepare(`
  SELECT i.nama_barang, i.sku, SUM(si.qty) as qty_sold, SUM(si.subtotal) as revenue
  FROM sales_items si JOIN inventory i ON si.inventory_id = i.id
  GROUP BY si.inventory_id ORDER BY qty_sold DESC LIMIT 5
`).all()).results as any[];

const totalProfit = stats?.total_profit || 0;
const totalAsset = stats?.total_aset || 0;
const totalSold = stats?.total_terjual || 0;
const todayExp = todayExpense?.total || 0;

interface StockItem {
  nama_barang: string; sku: string; satuan: string;
  stock_saat_ini: number; batas_stok_min: number;
  pct: number; barColor: string; numColor: string;
}

const stockView: StockItem[] = lowStockItems.map((item: any) => {
  const pct = item.batas_stok_min > 0 ? Math.min((item.stock_saat_ini / item.batas_stok_min) * 100, 100) : 0;
  const barColor = pct < 30 ? 'var(--danger)' : pct < 70 ? 'var(--warning)' : 'var(--success)';
  const numColor = pct < 30 ? 'var(--danger)' : 'var(--warning)';
  return { ...item, pct, barColor, numColor };
});

const paymentLabel = (m: string) => m === 'manual' ? 'Tunai' : m === 'qris' ? 'QRIS' : 'Transfer';
---

<Layout title="Dashboard" user={user} activePage="/dashboard">

  <!-- Premium Header -->
  <div class="premium-header">
    <div class="header-content">
      <div class="header-left">
        <div class="brand-badge">
          <span class="brand-text">KAY ID</span>
          <span class="brand-sub">TOKO BANGUNAN</span>
        </div>
        <div class="greeting-section">
          <h1>Selamat Datang, {user?.name || 'Admin'}</h1>
          <p class="date-text" id="currentDate"></p>
        </div>
      </div>
      <div class="header-right">
        <div class="clock-widget">
          <div class="clock-time" id="liveClock">--:--:--</div>
          <div class="clock-date" id="clockDateShort"></div>
        </div>
        <div class="quick-actions">
          <a href="/pos" class="action-btn action-primary">
            <span class="action-icon">🛒</span>
            <span>Kasir</span>
          </a>
          <a href="/sales" class="action-btn action-secondary">
            <span class="action-icon">📊</span>
            <span>Laporan</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Hero Finance Cards -->
  <div class="hero-grid">
    <div class="hero-card hero-card-primary">
      <div class="hero-bg-pattern"></div>
      <div class="hero-content">
        <div class="hero-icon-wrap">
          <span class="hero-icon">💰</span>
        </div>
        <div class="hero-data">
          <span class="hero-label">Nilai Aset Gudang</span>
          <span class="hero-value">{formatCurrency(totalAsset)}</span>
          <div class="hero-meta">
            <span class="meta-chip">{stats?.total_items || 0} produk</span>
            <span class="meta-chip">{stats?.total_stock || 0} unit</span>
          </div>
        </div>
      </div>
    </div>
    <div class="hero-card hero-card-success">
      <div class="hero-bg-pattern"></div>
      <div class="hero-content">
        <div class="hero-icon-wrap">
          <span class="hero-icon">💹</span>
        </div>
        <div class="hero-data">
          <span class="hero-label">Total Profit</span>
          <span class="hero-value">{formatCurrency(totalProfit)}</span>
          <div class="hero-meta">
            <span class="meta-chip">Dari {formatCurrency(totalSold)}</span>
          </div>
        </div>
      </div>
    </div>
    <div class="hero-card hero-card-warning">
      <div class="hero-bg-pattern"></div>
      <div class="hero-content">
        <div class="hero-icon-wrap">
          <span class="hero-icon">🧾</span>
        </div>
        <div class="hero-data">
          <span class="hero-label">Penjualan Hari Ini</span>
          <span class="hero-value">{formatCurrency(todaySales?.total || 0)}</span>
          <div class="hero-meta">
            <span class="meta-chip">{todaySales?.cnt || 0} transaksi</span>
            <span class="meta-chip">Pengeluaran: {formatCurrency(todayExp)}</span>
          </div>
        </div>
      </div>
    </div>
    <div class="hero-card hero-card-purple">
      <div class="hero-bg-pattern"></div>
      <div class="hero-content">
        <div class="hero-icon-wrap">
          <span class="hero-icon">📅</span>
        </div>
        <div class="hero-data">
          <span class="hero-label">Penjualan Bulan Ini</span>
          <span class="hero-value">{formatCurrency(monthSales?.total || 0)}</span>
          <div class="hero-meta">
            <span class="meta-chip">{monthSales?.cnt || 0} transaksi</span>
            <span class="meta-chip">{stats?.total_kategori || 0} kategori</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Stats -->
  <div class="stats-row">
    <div class="stat-pill">
      <div class="pill-icon pill-blue">📦</div>
      <div class="pill-data">
        <span class="pill-num">{stats?.total_items || 0}</span>
        <span class="pill-label">Total Produk</span>
      </div>
    </div>
    <div class="stat-pill">
      <div class="pill-icon pill-green">📊</div>
      <div class="pill-data">
        <span class="pill-num">{stats?.total_stock || 0}</span>
        <span class="pill-label">Total Stok</span>
      </div>
    </div>
    <div class="stat-pill stat-pill-alert">
      <div class="pill-icon pill-red">⚠️</div>
      <div class="pill-data">
        <span class="pill-num">{stats?.low_stock || 0}</span>
        <span class="pill-label">Stok Menipis</span>
      </div>
    </div>
    <div class="stat-pill stat-pill-success">
      <div class="pill-icon pill-emerald">💰</div>
      <div class="pill-data">
        <span class="pill-num">{formatCurrency(totalProfit)}</span>
        <span class="pill-label">Profit Kumulatif</span>
      </div>
    </div>
  </div>

  <!-- Section Title -->
  <div class="section-header">
    <h2 class="section-title">Ringkasan Data</h2>
    <div class="section-line"></div>
  </div>

  <!-- Bottom Grid -->
  <div class="bottom-grid">
    <!-- Penjualan Terbaru -->
    <div class="premium-card">
      <div class="premium-card-header">
        <div class="card-title-wrap">
          <span class="card-title-icon">📋</span>
          <h3>Penjualan Terbaru</h3>
        </div>
        <a href="/sales" class="card-action-btn">Lihat Semua</a>
      </div>
      <div class="premium-card-body">
        {recentSales.map((s: any, i: number) => (
          <div class="premium-row">
            <div class="premium-row-left">
              <div class="row-avatar">{s.invoice_no.substring(4, 6)}</div>
              <div class="row-info">
                <strong>{s.invoice_no}</strong>
                <span class="row-sub">{s.tanggal}</span>
              </div>
            </div>
            <div class="premium-row-right">
              <span class="row-amount">{formatCurrency(s.total)}</span>
              <span class={`row-badge row-badge-${s.payment_method}`}>{paymentLabel(s.payment_method)}</span>
            </div>
          </div>
        ))}
        {(!recentSales || recentSales.length === 0) && (
          <div class="premium-empty">
            <span class="empty-icon-lg">🧾</span>
            <span>Belum ada penjualan</span>
          </div>
        )}
      </div>
    </div>

    <!-- Produk Terlaris -->
    <div class="premium-card">
      <div class="premium-card-header">
        <div class="card-title-wrap">
          <span class="card-title-icon">🏆</span>
          <h3>Produk Terlaris</h3>
        </div>
        <a href="/inventory" class="card-action-btn">Kelola</a>
      </div>
      <div class="premium-card-body">
        {topProducts.map((p: any, i: number) => (
          <div class="premium-row">
            <div class="premium-row-left">
              <div class={`rank-circle rank-${i + 1}`}>#{i + 1}</div>
              <div class="row-info">
                <strong>{p.nama_barang}</strong>
                <span class="row-sub">{p.sku}</span>
              </div>
            </div>
            <div class="premium-row-right">
              <span class="row-amount">{p.qty_sold} unit</span>
              <span class="row-sub">{formatCurrency(p.revenue)}</span>
            </div>
          </div>
        ))}
        {(!topProducts || topProducts.length === 0) && (
          <div class="premium-empty">
            <span class="empty-icon-lg">📦</span>
            <span>Belum ada data penjualan</span>
          </div>
        )}
      </div>
    </div>

    <!-- Stok Menipis -->
    <div class="premium-card">
      <div class="premium-card-header">
        <div class="card-title-wrap">
          <span class="card-title-icon">⚠️</span>
          <h3>Stok Menipis</h3>
          <span class="count-badge">{stats?.low_stock || 0}</span>
        </div>
        <a href="/inventory" class="card-action-btn">Kelola</a>
      </div>
      <div class="premium-card-body">
        {stockView.map((item: StockItem, i: number) => (
          <div class="premium-row">
            <div class="premium-row-left">
              <div class="row-info">
                <strong>{item.nama_barang}</strong>
                <span class="row-sub">{item.sku} · {item.satuan}</span>
              </div>
            </div>
            <div class="premium-row-right">
              <div class="stock-progress">
                <div class="stock-bar-bg">
                  <div class="stock-bar-fill" style={`width:${item.pct}%;background:${item.barColor}`}></div>
                </div>
              </div>
              <span class="stock-value" style={`color:${item.numColor}`}>{item.stock_saat_ini}<span class="stock-min">/{item.batas_stok_min}</span></span>
            </div>
          </div>
        ))}
        {(!stockView || stockView.length === 0) && (
          <div class="premium-empty">
            <span class="empty-icon-lg">✅</span>
            <span>Semua stok aman</span>
          </div>
        )}
      </div>
    </div>
  </div>

  <script>
    function updateClock() {
      const now = new Date();
      const time = now.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
      const clock = document.getElementById('liveClock');
      if (clock) clock.textContent = time;

      const date = now.toLocaleDateString('id-ID', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
      const dateEl = document.getElementById('currentDate');
      if (dateEl) dateEl.textContent = date;

      const short = now.toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' });
      const shortEl = document.getElementById('clockDateShort');
      if (shortEl) shortEl.textContent = short;
    }
    updateClock();
    setInterval(updateClock, 1000);
  </script>

  <style>
    /* === PREMIUM HEADER === */
    .premium-header {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      border-radius: 1.25rem;
      padding: 1.75rem 2rem;
      margin-bottom: 1.5rem;
      box-shadow: 0 10px 40px rgba(15, 23, 42, 0.15);
      position: relative;
      overflow: hidden;
    }
    .premium-header::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -10%;
      width: 400px;
      height: 400px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, transparent 70%);
    }
    .header-content {
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: relative;
      z-index: 1;
    }
    .header-left {
      display: flex;
      align-items: center;
      gap: 1.25rem;
    }
    .brand-badge {
      background: linear-gradient(135deg, #3b82f6, #1d4ed8);
      padding: 0.75rem 1rem;
      border-radius: 0.85rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);
    }
    .brand-text {
      font-size: 1.1rem;
      font-weight: 800;
      color: white;
      letter-spacing: 1px;
    }
    .brand-sub {
      font-size: 0.55rem;
      color: rgba(255,255,255,0.8);
      font-weight: 600;
      letter-spacing: 0.5px;
    }
    .greeting-section h1 {
      font-size: 1.4rem;
      font-weight: 700;
      color: white;
      margin-bottom: 0.25rem;
    }
    .date-text {
      color: rgba(255,255,255,0.6);
      font-size: 0.8rem;
    }
    .header-right {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .clock-widget {
      background: rgba(255,255,255,0.08);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 0.85rem;
      padding: 0.75rem 1.1rem;
      text-align: center;
    }
    .clock-time {
      font-size: 1.4rem;
      font-weight: 700;
      font-family: 'SF Mono', 'Fira Code', monospace;
      color: #60a5fa;
      letter-spacing: 0.05em;
    }
    .clock-date {
      font-size: 0.65rem;
      color: rgba(255,255,255,0.5);
      margin-top: 0.1rem;
    }
    .quick-actions {
      display: flex;
      gap: 0.5rem;
    }
    .action-btn {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.6rem 1rem;
      border-radius: 0.7rem;
      font-size: 0.8rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.2s;
    }
    .action-primary {
      background: linear-gradient(135deg, #3b82f6, #2563eb);
      color: white;
      box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
    }
    .action-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(59, 130, 246, 0.4);
    }
    .action-secondary {
      background: rgba(255,255,255,0.1);
      color: white;
      border: 1px solid rgba(255,255,255,0.15);
    }
    .action-secondary:hover {
      background: rgba(255,255,255,0.15);
    }
    .action-icon { font-size: 1rem; }

    /* === HERO CARDS === */
    .hero-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
      margin-bottom: 1.25rem;
    }
    .hero-card {
      border-radius: 1.25rem;
      padding: 1.75rem;
      position: relative;
      overflow: hidden;
      transition: transform 0.25s, box-shadow 0.25s;
      cursor: default;
    }
    .hero-card:hover {
      transform: translateY(-4px);
    }
    .hero-card-primary {
      background: linear-gradient(135deg, #4338ca 0%, #6366f1 100%);
      box-shadow: 0 10px 30px rgba(67, 56, 202, 0.25);
    }
    .hero-card-success {
      background: linear-gradient(135deg, #047857 0%, #10b981 100%);
      box-shadow: 0 10px 30px rgba(4, 120, 87, 0.25);
    }
    .hero-card-warning {
      background: linear-gradient(135deg, #b45309 0%, #f59e0b 100%);
      box-shadow: 0 10px 30px rgba(180, 83, 9, 0.25);
    }
    .hero-card-purple {
      background: linear-gradient(135deg, #6d28d9 0%, #8b5cf6 100%);
      box-shadow: 0 10px 30px rgba(109, 40, 217, 0.25);
    }
    .hero-bg-pattern {
      position: absolute;
      top: -30%;
      right: -10%;
      width: 200px;
      height: 200px;
      border-radius: 50%;
      background: rgba(255,255,255,0.08);
    }
    .hero-content {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      position: relative;
      z-index: 1;
    }
    .hero-icon-wrap {
      width: 56px;
      height: 56px;
      border-radius: 1rem;
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(10px);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .hero-icon { font-size: 1.75rem; }
    .hero-data {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }
    .hero-label {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.8);
      font-weight: 500;
    }
    .hero-value {
      font-size: 1.6rem;
      font-weight: 800;
      color: white;
      letter-spacing: -0.02em;
      line-height: 1.2;
    }
    .hero-meta {
      display: flex;
      gap: 0.4rem;
      margin-top: 0.3rem;
      flex-wrap: wrap;
    }
    .meta-chip {
      font-size: 0.65rem;
      color: rgba(255,255,255,0.7);
      background: rgba(255,255,255,0.12);
      padding: 0.2rem 0.5rem;
      border-radius: 999px;
    }

    /* === STATS ROW === */
    .stats-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .stat-pill {
      background: white;
      border-radius: 1rem;
      padding: 1rem 1.15rem;
      display: flex;
      align-items: center;
      gap: 0.85rem;
      box-shadow: 0 2px 12px rgba(0,0,0,0.04);
      border: 1px solid var(--gray-100);
      transition: all 0.2s;
    }
    .stat-pill:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    }
    .stat-pill-alert { border-left: 3px solid var(--danger); }
    .stat-pill-success { border-left: 3px solid var(--success); }
    .pill-icon {
      width: 42px;
      height: 42px;
      border-radius: 0.7rem;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      flex-shrink: 0;
    }
    .pill-blue { background: linear-gradient(135deg, #e0e7ff, #c7d2fe); }
    .pill-green { background: linear-gradient(135deg, #d1fae5, #a7f3d0); }
    .pill-red { background: linear-gradient(135deg, #fee2e2, #fecaca); }
    .pill-emerald { background: linear-gradient(135deg, #a7f3d0, #6ee7b7); }
    .pill-data { display: flex; flex-direction: column; }
    .pill-num {
      font-size: 1.1rem;
      font-weight: 800;
      color: var(--gray-900);
      line-height: 1.2;
    }
    .pill-label { font-size: 0.7rem; color: var(--gray-500); font-weight: 500; }
    .stat-pill-alert .pill-num { color: var(--danger); }
    .stat-pill-success .pill-num { color: var(--success); font-size: 0.95rem; }

    /* === SECTION HEADER === */
    .section-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.25rem;
    }
    .section-title {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--gray-800);
      white-space: nowrap;
    }
    .section-line {
      flex: 1;
      height: 1px;
      background: linear-gradient(90deg, var(--gray-200), transparent);
    }

    /* === PREMIUM CARDS === */
    .bottom-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 1.25rem;
    }
    .premium-card {
      background: white;
      border-radius: 1.15rem;
      box-shadow: 0 4px 20px rgba(0,0,0,0.05);
      border: 1px solid var(--gray-100);
      overflow: hidden;
      transition: box-shadow 0.2s;
    }
    .premium-card:hover {
      box-shadow: 0 8px 32px rgba(0,0,0,0.08);
    }
    .premium-card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.1rem 1.35rem;
      border-bottom: 1px solid var(--gray-100);
    }
    .card-title-wrap {
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .card-title-icon { font-size: 1.2rem; }
    .card-title-wrap h3 {
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--gray-800);
    }
    .count-badge {
      background: var(--danger);
      color: white;
      font-size: 0.65rem;
      font-weight: 700;
      padding: 0.15rem 0.45rem;
      border-radius: 999px;
    }
    .card-action-btn {
      font-size: 0.72rem;
      color: var(--primary);
      text-decoration: none;
      font-weight: 600;
      padding: 0.35rem 0.7rem;
      border-radius: 0.5rem;
      background: var(--primary-light);
      transition: all 0.15s;
    }
    .card-action-btn:hover {
      background: #c7d2fe;
      color: var(--primary-dark);
    }
    .premium-card-body {
      padding: 0.5rem 0;
    }

    /* === PREMIUM ROWS === */
    .premium-row {
      display: flex;
      justify-content: space-between;
