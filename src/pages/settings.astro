---
import Layout from '../layouts/Layout.astro';
import { requireAuth, formatDate } from '../lib/auth';
import { getDB, getEnvFromLocals } from '../lib/db';

const env = getEnvFromLocals(Astro.locals);
const user = await requireAuth(env, Astro.request);
if (user instanceof Response) return user;

const db = await getDB(env);

// Get email settings
let settings = await db.prepare(`SELECT * FROM email_settings WHERE id = 'main'`).first() as any;
if (!settings) {
  settings = {
    id: 'main',
    resend_api_key: env.RESEND_API_KEY || '',
    recipient_emails: env.REPORT_EMAILS || '',
    weekly_enabled: 1,
    monthly_enabled: 1
  };
}

// Get email history (last 20)
const emailHistory = (await db.prepare(`
  SELECT * FROM email_history 
  ORDER BY sent_at DESC 
  LIMIT 20
`).all()).results as any[];
---

<Layout title="Pengaturan Email" user={user} activePage="/settings">
  <div class="page-header">
    <h1>⚙️ Pengaturan Email Laporan</h1>
  </div>

  <!-- Success/Error Messages -->
  <div id="messageBox" style="display:none;padding:1rem;border-radius:0.75rem;margin-bottom:1rem;"></div>

  <!-- Email Settings -->
  <div class="card mb-2">
    <h3 style="margin-bottom:1rem;">📧 Konfigurasi Email</h3>
    <form id="settingsForm" style="display:flex;flex-direction:column;gap:1rem;">
      <div class="form-group">
        <label>Resend API Key</label>
        <input type="password" name="resend_api_key" class="form-control" value={settings.resend_api_key} placeholder="re_xxxxxxxxxxxxx" />
        <small style="color:var(--gray-500);">Dapatkan dari <a href="https://resend.com/api-keys" target="_blank">resend.com/api-keys</a></small>
      </div>
      
      <div class="form-group">
        <label>Email Penerima (pisahkan dengan koma)</label>
        <input type="text" name="recipient_emails" class="form-control" value={settings.recipient_emails} placeholder="email1@gmail.com, email2@gmail.com" />
      </div>
      
      <div class="form-group">
        <label>Jadwal Laporan</label>
        <div style="display:flex;gap:1rem;flex-wrap:wrap;">
          <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
            <input type="checkbox" name="weekly_enabled" checked={settings.weekly_enabled === 1} />
            <span>Mingguan (Setiap Minggu jam 21:00)</span>
          </label>
          <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
            <input type="checkbox" name="monthly_enabled" checked={settings.monthly_enabled === 1} />
            <span>Bulanan (Tanggal terakhir jam 21:00)</span>
          </label>
        </div>
      </div>
      
      <button type="submit" class="btn btn-primary">💾 Simpan Pengaturan</button>
    </form>
  </div>

  <!-- Test Send -->
  <div class="card mb-2">
    <h3 style="margin-bottom:1rem;">🧪 Test Kirim Email</h3>
    <p style="color:var(--gray-500);margin-bottom:1rem;">Kirim test laporan untuk memastikan konfigurasi sudah benar.</p>
    <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
      <button id="testWeeklyBtn" class="btn btn-outline">📅 Test Laporan Mingguan</button>
      <button id="testMonthlyBtn" class="btn btn-outline">📆 Test Laporan Bulanan</button>
    </div>
  </div>

  <!-- Email History -->
  <div class="card">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
      <h3 style="margin:0;">📋 Riwayat Pengiriman Email</h3>
      {emailHistory.length > 0 && (
        <button id="clearHistoryBtn" class="btn btn-sm btn-outline" style="color:var(--danger);border-color:var(--danger);">🗑️ Hapus Semua</button>
      )}
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Tanggal</th><th>Jenis</th><th>Periode</th><th>Penerima</th><th>Status</th><th style="width:60px;"></th></tr>
        </thead>
        <tbody>
          {emailHistory.map((h: any) => (
            <tr>
              <td>{formatDate(h.sent_at)}</td>
              <td>
                <span class={`badge ${h.type === 'weekly' ? 'badge-info' : 'badge-warning'}`}>
                  {h.type === 'weekly' ? '📅 Mingguan' : '📆 Bulanan'}
                </span>
              </td>
              <td>{h.period_label || '-'}</td>
              <td style="font-size:0.85rem;">{h.recipients}</td>
              <td>
                {h.status === 'sent' ? (
                  <span class="badge badge-success">✓ Terkirim</span>
                ) : (
                  <span class="badge badge-danger" title={h.error_message}>✗ Gagal</span>
                )}
              </td>
              <td>
                <button onclick="deleteHistory('${h.id}')" class="btn btn-sm btn-outline" style="color:var(--danger);border-color:var(--danger);padding:2px 8px;font-size:0.7rem;">✕</button>
              </td>
            </tr>
          ))}
          {emailHistory.length === 0 && (
            <tr><td colspan="6" class="text-center" style="padding:2rem;color:var(--gray-500);">Belum ada riwayat pengiriman</td></tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

  <script>
    const settingsForm = document.getElementById('settingsForm');
    const messageBox = document.getElementById('messageBox');
    const testWeeklyBtn = document.getElementById('testWeeklyBtn');
    const testMonthlyBtn = document.getElementById('testMonthlyBtn');
    
    settingsForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(settingsForm);
      
      const data = {
        resend_api_key: formData.get('resend_api_key'),
        recipient_emails: formData.get('recipient_emails'),
        weekly_enabled: formData.get('weekly_enabled') ? 1 : 0,
        monthly_enabled: formData.get('monthly_enabled') ? 1 : 0
      };
      
      const res = await fetch('/api/settings/email', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      
      const result = await res.json();
      
      messageBox.style.display = 'block';
      if (result.success) {
        messageBox.style.background = '#d1fae5';
        messageBox.style.color = '#065f46';
        messageBox.textContent = '✓ Pengaturan berhasil disimpan!';
      } else {
        messageBox.style.background = '#fee2e2';
        messageBox.style.color = '#991b1b';
        messageBox.textContent = '✗ Gagal menyimpan: ' + (result.error || 'Unknown error');
      }
      
      setTimeout(() => {
        messageBox.style.display = 'none';
      }, 3000);
    });
    
    async function testSend(type) {
      messageBox.style.display = 'block';
      messageBox.style.background = '#dbeafe';
      messageBox.style.color = '#1e40af';
      messageBox.textContent = '⏳ Mengirim email...';
      
      try {
        const res = await fetch('/api/reports/send-email?type=' + type, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type })
        });
        
        const result = await res.json();
        
        if (result.success) {
          messageBox.style.background = '#d1fae5';
          messageBox.style.color = '#065f46';
          messageBox.textContent = '✓ Email test berhasil dikirim! Cek inbox email kamu.';
        } else {
          messageBox.style.background = '#fee2e2';
          messageBox.style.color = '#991b1b';
          messageBox.textContent = '✗ Gagal mengirim: ' + (result.error || 'Unknown error');
        }
      } catch (error) {
        messageBox.style.background = '#fee2e2';
        messageBox.style.color = '#991b1b';
        messageBox.textContent = '✗ Error: ' + error.message;
      }
      
      setTimeout(() => {
        location.reload();
      }, 2000);
    }
    
    testWeeklyBtn.addEventListener('click', () => testSend('weekly'));
    testMonthlyBtn.addEventListener('click', () => testSend('monthly'));
    
    const clearHistoryBtn = document.getElementById('clearHistoryBtn');
    if (clearHistoryBtn) {
      clearHistoryBtn.addEventListener('click', async () => {
        if (!confirm('Hapus semua riwayat pengiriman email?')) return;
        const res = await fetch('/api/settings/email-history', { method: 'DELETE' });
        const result = await res.json();
        if (result.success) location.reload();
      });
    }
    
    window.deleteHistory = async function(id) {
      if (!confirm('Hapus riwayat ini?')) return;
      const res = await fetch('/api/settings/email-history?id=' + id, { method: 'DELETE' });
      const result = await res.json();
      if (result.success) location.reload();
    };
  </script>
</Layout>

<style>
  .badge-info { background: #dbeafe; color: #1e40af; }
  .badge-warning { background: #fef3c7; color: #92400e; }
</style>
