---
import Layout from '../layouts/Layout.astro';
import { requireAuth, formatCurrency } from '../lib/auth';
import { getDB } from '../lib/db';

const user = await requireAuth(Astro.request);
if (user instanceof Response) return user;

const db = await getDB(Astro.request);

const url = new URL(Astro.request.url);
const search = url.searchParams.get('q') || '';
const kategori = url.searchParams.get('kategori') || '';

let query = 'SELECT * FROM inventory WHERE 1=1';
const params: string[] = [];

if (search) {
  query += ' AND (nama_barang LIKE ? OR sku LIKE ? OR barcode LIKE ?)';
  params.push(`%${search}%`, `%${search}%`, `%${search}%`);
}
if (kategori) {
  query += ' AND kategori = ?';
  params.push(kategori);
}

query += ' ORDER BY created_at DESC';

const items = params.length > 0
  ? (await db.prepare(query).bind(...params).all()).results as any[]
  : (await db.prepare(query).all()).results as any[];

const categories = (await db.prepare('SELECT DISTINCT kategori FROM inventory WHERE kategori IS NOT NULL').all()).results as any[];
---

<Layout title="Inventory" user={user} activePage="/inventory">
  <div class="page-header">
    <h1>Inventory / Master Barang</h1>
    <button class="btn btn-primary" onclick="document.getElementById('addModal').classList.remove('hidden')">+ Tambah Barang</button>
  </div>

  <div class="card">
    <div class="search-bar">
      <form method="GET" style="display:flex;gap:0.5rem;flex:1;">
        <input type="text" name="q" value={search} placeholder="Cari nama, SKU, atau barcode..." class="form-control" style="flex:1;" />
        <select name="kategori" class="form-control" style="width:180px;">
          <option value="">Semua Kategori</option>
          {categories.map((c: any) => (
            <option value={c.kategori} selected={kategori === c.kategori}>{c.kategori}</option>
          ))}
        </select>
        <button type="submit" class="btn btn-primary">Cari</button>
        <a href="/inventory" class="btn btn-outline">Reset</a>
      </form>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>SKU</th><th>Barcode</th><th>Nama Barang</th><th>Merk</th><th>Kategori</th>
            <th>Satuan</th><th>Stock</th><th>Min</th><th>Harga Beli</th><th>Harga Jual</th>
            <th>Nilai Aset</th><th>Profit</th><th>Status</th><th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          {items.map((item: any) => (
            <tr>
              <td><code>{item.sku}</code></td>
              <td><code>{item.barcode || '-'}</code></td>
              <td><strong>{item.nama_barang}</strong></td>
              <td>{item.merk || '-'}</td>
              <td><span class="badge badge-info">{item.kategori || '-'}</span></td>
              <td>{item.satuan}</td>
              <td><strong>{item.stock_saat_ini}</strong></td>
              <td>{item.batas_stok_min}</td>
              <td>{formatCurrency(item.harga_beli_awal)}</td>
              <td>{formatCurrency(item.harga_jual_eceran)}</td>
              <td>{formatCurrency(item.nilai_aset)}</td>
              <td style="color:var(--success);">{formatCurrency(item.keuntungan_penjualan)}</td>
              <td>
                {item.stock_saat_ini <= item.batas_stok_min
                  ? <span class="badge badge-danger">MENIPIS</span>
                  : <span class="badge badge-success">AMAN</span>}
              </td>
              <td>
                <div class="flex gap-1">
                  <a href={`/api/inventory/${item.id}/edit`} class="btn btn-outline btn-sm">Edit</a>
                  <form action={`/api/inventory/${item.id}/delete`} method="POST" style="display:inline;">
                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Hapus barang ini?')">Hapus</button>
                  </form>
                </div>
              </td>
            </tr>
          ))}
          {items.length === 0 && (
            <tr><td colspan="14" class="text-center" style="padding:2rem;color:var(--gray-500);">Tidak ada data. Tambah barang pertama Anda.</td></tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Add Modal -->
  <div id="addModal" class="modal-overlay hidden">
    <div class="modal">
      <div class="modal-header">
        <h2>Tambah Barang Baru</h2>
        <button class="modal-close" onclick="document.getElementById('addModal').classList.add('hidden')">&times;</button>
      </div>
      <form action="/api/inventory/create" method="POST">
        <div class="grid-2">
          <div class="form-group">
            <label>Nama Barang *</label>
            <input type="text" name="nama_barang" class="form-control" required />
          </div>
          <div class="form-group">
            <label>Merk / Brand</label>
            <input type="text" name="merk" class="form-control" />
          </div>
          <div class="form-group">
            <label>Kategori</label>
            <input type="text" name="kategori" class="form-control" placeholder="Semen, Besi, Cat, dll" />
          </div>
          <div class="form-group">
            <label>Satuan *</label>
            <input type="text" name="satuan" class="form-control" required placeholder="Sak, Batang, Kg, Liter" />
          </div>
          <div class="form-group">
            <label>Barcode</label>
            <input type="text" name="barcode" class="form-control" placeholder="Scan atau ketik barcode" />
          </div>
          <div class="form-group">
            <label>Lokasi Rak / Gudang</label>
            <input type="text" name="lokasi_rak" class="form-control" />
          </div>
          <div class="form-group">
            <label>Supplier Utama</label>
            <input type="text" name="supplier" class="form-control" />
          </div>
          <div class="form-group">
            <label>Batas Stok Minimum</label>
            <input type="number" name="batas_stok_min" class="form-control" value="5" />
          </div>
          <div class="form-group">
            <label>Stock Awal</label>
            <input type="number" name="stock_awal" class="form-control" value="0" />
          </div>
          <div class="form-group">
            <label>Harga Beli Awal (Rp)</label>
            <input type="number" name="harga_beli_awal" class="form-control" value="0" />
          </div>
          <div class="form-group">
            <label>Harga Jual Eceran (Rp)</label>
            <input type="number" name="harga_jual_eceran" class="form-control" value="0" />
          </div>
          <div class="form-group">
            <label>Harga Jual Grosir (Rp)</label>
            <input type="number" name="harga_jual_grosir" class="form-control" value="0" />
          </div>
        </div>
        <div class="form-group">
          <label>Keterangan</label>
          <textarea name="keterangan" class="form-control"></textarea>
        </div>
        <div class="flex gap-1" style="justify-content:flex-end;margin-top:1rem;">
          <button type="button" class="btn btn-outline" onclick="document.getElementById('addModal').classList.add('hidden')">Batal</button>
          <button type="submit" class="btn btn-primary">Simpan Barang</button>
        </div>
      </form>
    </div>
  </div>
</Layout>
