  <!-- Hidden element to store items data for client-side JS -->
  <div id="itemsDataStore" data-items={itemsJSON} style="display:none"></div>

  <script is:inline>
    // Item data array for edit functionality - read from data attribute
    let itemsData = [];
    try {
      const store = document.getElementById('itemsDataStore');
      if (store) {
        itemsData = JSON.parse(store.getAttribute('data-items') || '[]');
      }
    } catch (e) {
      console.error('Failed to parse items data:', e);
    }

    function handleEditClick(btn) {
      const itemId = btn.getAttribute('data-item-id');
      const item = itemsData.find(i => i.id === itemId);
      if (!item) {
        alert('Data barang tidak ditemukan');
        return;
      }
      openEditModal(
        item.id, item.sku, item.nama_barang, item.merk, item.kategori,
        item.satuan, item.lokasi_rak, item.supplier, item.stock_saat_ini,
        item.batas_stok_min, item.harga_beli_awal, item.harga_jual_eceran,
        item.harga_jual_grosir, item.keterangan
      );
    }

    function showQR(id, sku) {
      document.getElementById('qrModalSku').textContent = sku;
      document.getElementById('qrImage').src = `/api/inventory/${id}/qr`;
      document.getElementById('qrDownload').href = `/api/inventory/${id}/qr`;
      // Set location text from itemsData
      const item = itemsData.find(i => i.id === id);
      const locationText = item && item.lokasi_rak ? `Rak ${item.lokasi_rak}` : 'Lokasi tidak tersedia';
      document.getElementById('qrLocationText').textContent = locationText;
      document.getElementById('qrModal').classList.remove('hidden');
    }

    function printQR() {
      const img = document.getElementById('qrImage');
      const sku = document.getElementById('qrModalSku').textContent;
      const w = window.open('', '_blank');
      w.document.write(`
        <html><head><title>QR ${sku}</title>
        <style>body{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;font-family:sans-serif;}
        img{width:250px;height:250px;}p{font-size:1.2rem;font-weight:bold;margin-top:1rem;}</style></head>
        <body><img src="${img.src}" /><p>${sku}</p></body></html>
      `);
      w.document.close();
      w.print();
    }

    function openAddModal() {
      document.getElementById('addModal').classList.remove('hidden');
      document.getElementById('skuPreviewValue').textContent = '-';
      document.querySelector('input[name="nama_barang"]').focus();
    }

    function closeAddModal() {
      document.getElementById('addModal').classList.add('hidden');
      document.getElementById('addItemForm').reset();
      document.getElementById('skuPreviewValue').textContent = '-';
    }

    // Edit modal functions
    function openEditModal(id, sku, nama, merk, kategori, satuan, lokasi, supplier, stock, minStock, hargaBeli, hargaJual, hargaGrosir, keterangan) {
      document.getElementById('editItemId').value = id;
      document.getElementById('editModalSku').textContent = 'SKU: ' + sku;
      document.getElementById('editNama').value = nama;
      document.getElementById('editMerk').value = merk;
      document.getElementById('editKategori').value = kategori;
      document.getElementById('editSatuan').value = satuan;
      document.getElementById('editLokasi').value = lokasi;
      document.getElementById('editSupplier').value = supplier;
      document.getElementById('editStock').value = stock;
      document.getElementById('editMinStock').value = minStock;
      document.getElementById('editHargaBeli').value = hargaBeli;
      document.getElementById('editHargaJual').value = hargaJual;
      document.getElementById('editHargaGrosir').value = hargaGrosir;
      document.getElementById('editKeterangan').value = keterangan;
      document.getElementById('editModal').classList.remove('hidden');
    }

    function closeEditModal() {
      document.getElementById('editModal').classList.add('hidden');
      document.getElementById('editItemForm').reset();
    }

    function adjustNumber(id, delta) {
      const input = document.getElementById(id);
      let val = parseInt(input.value) || 0;
      val = Math.max(0, val + delta);
      input.value = val;
    }

    async function submitItem(e) {
      e.preventDefault();
      const form = e.target;
      const btn = document.getElementById('submitBtn');
      const originalText = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<span>⏳</span> Menyimpan...';

      const formData = new FormData(form);

      try {
        const res = await fetch('/api/inventory/create', {
          method: 'POST',
          body: formData,
        });

        if (res.ok) {
          const data = await res.json();
          closeAddModal();
          showToast(`✅ ${data.nama_barang || 'Barang'} berhasil disimpan! SKU: ${data.sku}`);
          setTimeout(() => location.reload(), 1800);
        } else {
          const err = await res.text();
          alert('Gagal menyimpan: ' + err);
        }
      } catch (err) {
        alert('Error: ' + err.message);
      } finally {
        btn.disabled = false;
        btn.innerHTML = originalText;
      }
      return false;
    }

    async function submitEdit(e) {
      e.preventDefault();
      const form = e.target;
      const btn = document.getElementById('editSubmitBtn');
      const originalText = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<span>⏳</span> Mengupdate...';

      const formData = new FormData(form);
      const id = formData.get('id');

      try {
        const res = await fetch(`/api/inventory/${id}/update`, {
          method: 'POST',
          body: formData,
        });

        if (res.ok) {
          const data = await res.json();
          closeEditModal();
          showToast(`✅ ${data.nama_barang || 'Barang'} berhasil diupdate!`);
          setTimeout(() => location.reload(), 1800);
        } else {
          const err = await res.text();
          alert('Gagal mengupdate: ' + err);
        }
      } catch (err) {
        alert('Error: ' + err.message);
      } finally {
        btn.disabled = false;
        btn.innerHTML = originalText;
      }
      return false;
    }

    function showToast(msg) {
      const toast = document.getElementById('successToast');
      document.getElementById('toastMsg').textContent = msg;
      toast.classList.remove('hidden');
      setTimeout(() => toast.classList.add('hidden'), 4000);
    }

    // Live SKU preview when typing category
    const kategoriInput = document.getElementById('kategoriInput');
    if (kategoriInput) {
      kategoriInput.addEventListener('input', function() {
        const val = this.value.trim();
        const preview = document.getElementById('skuPreviewValue');
        if (val.length >= 1) {
          const prefix = val.substring(0, 3).toUpperCase().replace(/[^A-Z0-9]/g, 'X');
          preview.textContent = `${prefix}-001`;
          preview.classList.add('has-value');
        } else {
          preview.textContent = '-';
          preview.classList.remove('has-value');
        }
      });
    }

    // Close modal on outside click
    document.getElementById('addModal').addEventListener('click', function(e) {
      if (e.target === this) closeAddModal();
    });
    document.getElementById('qrModal').addEventListener('click', function(e) {
      if (e.target === this) this.classList.add('hidden');
    });
    document.getElementById('editModal').addEventListener('click', function(e) {
      if (e.target === this) closeEditModal();
    });
  </script>

