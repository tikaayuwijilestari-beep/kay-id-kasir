---
import Layout from '../layouts/Layout.astro';
import { requireAuth, formatCurrency } from '../lib/auth';
import { getDB, getEnvFromLocals } from '../lib/db';

const env = getEnvFromLocals(Astro.locals);
const user = await requireAuth(env, Astro.request);
if (user instanceof Response) return user;

const db = await getDB(env);

const url = new URL(Astro.request.url);
const search = url.searchParams.get('q') || '';
const kategori = url.searchParams.get('kategori') || '';
const statusFilter = url.searchParams.get('status') || '';

let query = 'SELECT * FROM inventory WHERE 1=1';
const params: string[] = [];

if (search) {
  query += ' AND (nama_barang LIKE ? OR sku LIKE ? OR merk LIKE ?)';
  params.push(`%${search}%`, `%${search}%`, `%${search}%`);
}
if (kategori) {
  query += ' AND kategori = ?';
  params.push(kategori);
}
if (statusFilter === 'low') {
  query += ' AND stock_saat_ini <= batas_stok_min';
} else if (statusFilter === 'safe') {
  query += ' AND stock_saat_ini > batas_stok_min';
}

query += ' ORDER BY created_at DESC';

const items = params.length > 0
  ? (await db.prepare(query).bind(...params).all()).results as any[]
  : (await db.prepare(query).all()).results as any[];

const categories = (await db.prepare('SELECT DISTINCT kategori FROM inventory WHERE kategori IS NOT NULL ORDER BY kategori').all()).results as any[];

const summary = await db.prepare(`
  SELECT
    COUNT(*) as total,
    SUM(nilai_aset) as total_value,
    SUM(CASE WHEN stock_saat_ini <= batas_stok_min THEN 1 ELSE 0 END) as low_stock,
    COUNT(DISTINCT kategori) as total_cat,
    SUM(stock_saat_ini) as total_units
  FROM inventory
`).first() as any;

interface ItemView {
  id: string; sku: string; nama_barang: string; merk: string; kategori: string;
  satuan: string; lokasi_rak: string; stock_saat_ini: number; batas_stok_min: number;
  harga_beli_awal: number; harga_jual_eceran: number; harga_jual_grosir: number; nilai_aset: number;
  status_stok: string; cardClass: string; statusClass: string; statusText: string;
  stockPct: number; stockColor: string;
}

const itemsView: ItemView[] = items.map((item: any) => {
  const isLow = item.stock_saat_ini <= item.batas_stok_min;
  const stockPct = item.batas_stok_min > 0 ? Math.min((item.stock_saat_ini / (item.batas_stok_min * 3)) * 100, 100) : 50;
  return {
    ...item,
    cardClass: isLow ? 'item-card item-low' : 'item-card',
    statusClass: isLow ? 'item-status status-low' : 'item-status status-ok',
    statusText: isLow ? 'MENIPIS' : 'AMAN',
    stockPct,
    stockColor: isLow ? 'var(--danger)' : stockPct < 50 ? 'var(--warning)' : 'var(--success)',
  };
});

// Create JSON string for client-side edit functionality
const itemsJSON = JSON.stringify(items.map((item: any) => ({
  id: item.id,
  sku: item.sku,
  nama_barang: item.nama_barang,
  merk: item.merk || '',
  kategori: item.kategori || '',
  satuan: item.satuan,
  lokasi_rak: item.lokasi_rak || '',
  supplier: item.supplier || '',
  stock_saat_ini: item.stock_saat_ini,
  batas_stok_min: item.batas_stok_min,
  harga_beli_awal: item.harga_beli_awal,
  harga_jual_eceran: item.harga_jual_eceran,
  harga_jual_grosir: item.harga_jual_grosir,
  keterangan: item.keterangan || ''
})));

// Build PDF export URL with current filters
let pdfUrl = '/api/reports/inventory-pdf';
if (statusFilter) pdfUrl += `?type=${statusFilter}`;

// Precompute chip filter URLs
const baseQs = `q=${encodeURIComponent(search)}&kategori=${encodeURIComponent(kategori)}`;
const chipAllUrl = `/inventory?${baseQs}`;
const chipSafeUrl = `/inventory?${baseQs}&status=safe`;
const chipLowUrl = `/inventory?${baseQs}&status=low`;
---

<Layout title="Inventory" user={user} activePage="/inventory">
  <div class="page-header">
    <div>
      <h1>Inventory</h1>
      <p class="page-sub">Kelola semua barang toko bangunan Anda</p>
    </div>
    <div class="header-actions">
      <a href="/scan" class="btn btn-outline">📱 Scan QR</a>
      <a href={pdfUrl} class="btn btn-outline" target="_blank">📄 Export PDF</a>
      <button class="btn btn-primary btn-lg" onclick="openAddModal()">
        <span class="btn-icon">+</span> Tambah Barang
      </button>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="summary-grid">
    <div class="sum-card">
      <div class="sum-icon sum-blue">📦</div>
      <div class="sum-info">
        <span class="sum-value">{summary?.total || 0}</span>
        <span class="sum-label">Total Produk</span>
      </div>
    </div>
    <div class="sum-card">
      <div class="sum-icon sum-green">💰</div>
      <div class="sum-info">
        <span class="sum-value">{formatCurrency(summary?.total_value || 0)}</span>
        <span class="sum-label">Nilai Aset</span>
      </div>
    </div>
    <div class="sum-card">
      <div class="sum-icon sum-amber"></div>
      <div class="sum-info">
        <span class="sum-value">{summary?.total_units || 0}</span>
        <span class="sum-label">Total Unit</span>
      </div>
    </div>
    <div class="sum-card">
      <div class="sum-icon sum-red">⚠️</div>
      <div class="sum-info">
        <span class="sum-value">{summary?.low_stock || 0}</span>
        <span class="sum-label">Stok Menipis</span>
      </div>
    </div>
  </div>

  <!-- Search & Filter Bar -->
  <div class="filter-bar">
    <form method="GET" class="search-form">
      <div class="search-input-wrap">
        <span class="search-icon">🔍</span>
        <input type="text" name="q" value={search} placeholder="Cari nama barang, SKU, atau merk..." class="search-input" />
      </div>
      <select name="kategori" class="filter-select">
        <option value="">Semua Kategori</option>
        {categories.map((c: any) => (
          <option value={c.kategori} selected={kategori === c.kategori}>{c.kategori}</option>
        ))}
      </select>
      {statusFilter && <input type="hidden" name="status" value={statusFilter} />}
      <div class="status-chips">
        <a href={chipAllUrl} class={`chip ${!statusFilter ? 'chip-active' : ''}`}>Semua</a>
        <a href={chipSafeUrl} class={`chip ${statusFilter === 'safe' ? 'chip-active chip-safe' : ''}`}>✅ Aman</a>
        <a href={chipLowUrl} class={`chip ${statusFilter === 'low' ? 'chip-active chip-danger' : ''}`}>⚠️ Menipis</a>
      </div>
      <button type="submit" class="btn btn-primary">Cari</button>
      <a href="/inventory" class="btn btn-outline">Reset</a>
    </form>
  </div>

  <!-- Results Count -->
  <div class="toolbar">
    <div class="results-info">
      Menampilkan <strong>{itemsView.length}</strong> dari <strong>{summary?.total || 0}</strong> produk
      {kategori && <span class="active-filter">Kategori: {kategori}</span>}
      {search && <span class="active-filter">Pencarian: "{search}"</span>}
    </div>
  </div>
  
  <!-- Table View -->
  <div class="table-view" id="tableView">
    <div class="table-card">
      <table>
        <thead>
          <tr>
            <th>SKU</th>
            <th>QR</th>
            <th>Nama Barang</th>
            <th>Merk</th>
            <th>Kategori</th>
            <th>Satuan</th>
            <th>Lokasi</th>
            <th class="th-right">Stok</th>
            <th class="th-right">Min</th>
            <th class="th-right">H. Beli</th>
            <th class="th-right">H. Jual</th>
            <th class="th-right">Nilai Aset</th>
            <th>Status</th>
            <th class="th-right">Aksi</th>
          </tr>
        </thead>
        <tbody>
          {itemsView.map((item: ItemView, i: number) => (
            <tr class:list={[{ 'row-alt': i % 2 === 1 }]}>
              <td><code class="sku-code">{item.sku}</code></td>
              <td><button class="qr-btn-sm" onclick={`showQR('${item.id}', '${item.sku}')`}>📱</button></td>
              <td><strong>{item.nama_barang}</strong></td>
              <td>{item.merk || '-'}</td>
              <td>{item.kategori || '-'}</td>
              <td>{item.satuan}</td>
              <td>{item.lokasi_rak || '-'}</td>
              <td class="td-right"><strong>{item.stock_saat_ini}</strong></td>
              <td class="td-right">{item.batas_stok_min}</td>
              <td class="td-right">{formatCurrency(item.harga_beli_awal)}</td>
              <td class="td-right">{formatCurrency(item.harga_jual_eceran)}</td>
              <td class="td-right">{formatCurrency(item.nilai_aset)}</td>
              <td><span class={item.statusClass}>{item.statusText}</span></td>
              <td class="td-right">
                <div class="action-btns">
                  <button class="btn-edit" data-item-id={item.id} onclick="handleEditClick(this)" title="Edit">✏️</button>
                  <form action={`/api/inventory/${item.id}/delete`} method="POST" style="display:inline;">
                    <button type="submit" class="btn-delete" onclick={`return confirm('Hapus ${item.nama_barang}?')`}>🗑️</button>
                  </form>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      {itemsView.length === 0 && (
        <div class="table-empty">
          <span class="empty-icon"></span>
          <h3>Belum ada barang</h3>
          <p>Klik tombol "Tambah Barang" untuk menambahkan barang pertama Anda.</p>
          <button class="btn btn-primary" onclick="openAddModal()">+ Tambah Barang</button>
        </div>
      )}
    </div>
  </div>

  <!-- QR Modal -->
  <div id="qrModal" class="modal-overlay hidden">
    <div class="modal qr-modal">
      <div class="modal-header">
        <div>
          <h2>QR Code Barang</h2>
          <p class="modal-sub" id="qrModalSku">-</p>
        </div>
        <button class="modal-close" onclick="document.getElementById('qrModal').classList.add('hidden')">&times;</button>
      </div>
      <div class="qr-display">
        <img id="qrImage" src="" alt="QR Code" />
        <div class="qr-logo-overlay">
          <div class="qr-logo-box">Kay</div>
        </div>
      </div>
      <div class="qr-location" id="qrLocation">
        <span class="qr-location-icon">📍</span>
        <span class="qr-location-text" id="qrLocationText">-</span>
      </div>
      <p class="qr-hint">Scan QR ini untuk melihat detail barang (tanpa login)</p>
      <div class="qr-actions">
        <a id="qrDownload" class="btn btn-primary" download>⬇️ Download QR</a>
        <button class="btn btn-outline" onclick="printQR()">🖨️ Print QR</button>
      </div>
    </div>
  </div>

  <!-- Add Modal -->
  <div id="addModal" class="modal-overlay hidden">
    <div class="modal add-modal">
      <div class="modal-header">
        <div class="modal-title-wrap">
          <div class="modal-icon">📦</div>
          <div>
            <h2>Tambah Barang Baru</h2>
            <p class="modal-sub">Isi data barang, SKU & QR Code akan dibuat otomatis oleh sistem</p>
          </div>
        </div>
        <button class="modal-close" onclick="closeAddModal()">&times;</button>
      </div>

      <form id="addItemForm" onsubmit="return submitItem(event)">
        <!-- SKU Preview Banner -->
        <div class="sku-banner">
          <span class="sku-banner-label">Kode SKU yang akan dibuat:</span>
          <span class="sku-banner-value" id="skuPreviewValue">-</span>
          <span class="sku-banner-hint">tergantung kategori yang dipilih</span>
        </div>

        <!-- Section 1: Identitas Barang -->
        <div class="form-panel">
          <div class="panel-header">
            <span class="panel-icon">🏷️</span>
            <span class="panel-title">Identitas Barang</span>
          </div>
          <div class="form-grid">
            <div class="form-group fg-2">
              <label class="field-label">Nama Barang <span class="required">*</span></label>
              <div class="input-wrap">
                <span class="input-icon">📋</span>
                <input type="text" name="nama_barang" class="form-control input-with-icon" required placeholder="Contoh: Semen Portland 50kg" />
              </div>
            </div>
            <div class="form-group">
              <label class="field-label">Merk / Brand</label>
              <div class="input-wrap">
                <span class="input-icon">©️</span>
                <input type="text" name="merk" class="form-control input-with-icon" placeholder="Contoh: Holcim" />
              </div>
            </div>
            <div class="form-group">
              <label class="field-label">Kategori <span class="required">*</span></label>
              <div class="input-wrap">
                <span class="input-icon">🏗️</span>
                <input type="text" name="kategori" id="kategoriInput" class="form-control input-with-icon" required list="kategoriList" placeholder="Pilih atau ketik kategori" />
                <datalist id="kategoriList">
                  <option value="Semen" />
                  <option value="Besi" />
                  <option value="Cat" />
                  <option value="Kayu" />
                  <option value="Pasir" />
                  <option value="Bata" />
                  <option value="Keramik" />
                  <option value="Pipa" />
                  <option value="Alat Listrik" />
                  <option value="Alat Bangunan" />
                  {categories.map((c: any) => <option value={c.kategori} />)}
                </datalist>
              </div>
              <small class="field-hint">SKU otomatis dari kategori: Semen → SMN-001, Besi → BSI-001</small>
            </div>
            <div class="form-group">
              <label class="field-label">Satuan <span class="required">*</span></label>
              <div class="input-wrap">
                <span class="input-icon">⚖️</span>
                <input type="text" name="satuan" class="form-control input-with-icon" required list="satuanList" placeholder="Sak, Kg, Batang..." />
                <datalist id="satuanList">
                  <option value="Sak" />
                  <option value="Kg" />
                  <option value="Batang" />
                  <option value="Liter" />
                  <option value="Meter" />
                  <option value="Buah" />
                  <option value="Roll" />
                  <option value="Box" />
                </datalist>
              </div>
            </div>
          </div>
        </div>

        <!-- Section 2: Lokasi & Supplier -->
        <div class="form-panel">
          <div class="panel-header">
            <span class="panel-icon">📍</span>
            <span class="panel-title">Lokasi & Supplier</span>
          </div>
          <div class="form-grid cols-2">
            <div class="form-group">
              <label class="field-label">Lokasi Rak / Gudang</label>
              <div class="input-wrap">
                <span class="input-icon">🗺️</span>
                <input type="text" name="lokasi_rak" class="form-control input-with-icon" placeholder="Contoh: Rak A3, Gudang 2" />
              </div>
            </div>
            <div class="form-group">
              <label class="field-label">Supplier Utama</label>
              <div class="input-wrap">
                <span class="input-icon">🚚</span>
                <input type="text" name="supplier" class="form-control input-with-icon" placeholder="Contoh: Toko Istana" />
              </div>
            </div>
          </div>
        </div>

        <!-- Section 3: Stok -->
        <div class="form-panel">
          <div class="panel-header">
            <span class="panel-icon">📊</span>
            <span class="panel-title">Pengaturan Stok</span>
          </div>
          <div class="form-grid cols-3">
            <div class="form-group">
              <label class="field-label">Stok Awal</label>
              <div class="number-stepper">
                <button type="button" class="stepper-btn" onclick="adjustNumber('stock_awal', -1)">−</button>
                <input type="number" name="stock_awal" id="stock_awal" class="form-control stepper-input" value="0" min="0" />
                <button type="button" class="stepper-btn" onclick="adjustNumber('stock_awal', 1)">+</button>
              </div>
            </div>
            <div class="form-group">
              <label class="field-label">Batas Stok Minimum</label>
              <div class="number-stepper">
                <button type="button" class="stepper-btn" onclick="adjustNumber('batas_stok_min', -1)">−</button>
                <input type="number" name="batas_stok_min" id="batas_stok_min" class="form-control stepper-input" value="5" min="0" />
                <button type="button" class="stepper-btn" onclick="adjustNumber('batas_stok_min', 1)">+</button>
              </div>
            </div>
            <div class="form-group stock-info-box">
              <div class="stock-info-content">
                <span class="info-icon">💡</span>
                <p>Barang akan otomatis ditandai <strong>"MENIPIS"</strong> jika stok saat ini ≤ batas minimum.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Section 4: Harga -->
        <div class="form-panel">
          <div class="panel-header">
            <span class="panel-icon">💰</span>
            <span class="panel-title">Harga</span>
          </div>
          <div class="form-grid cols-3">
            <div class="form-group">
              <label class="field-label">Harga Beli</label>
              <div class="input-wrap">
                <span class="rp-prefix">Rp</span>
                <input type="text" name="harga_beli_awal" class="form-control input-with-prefix" value="0" placeholder="0" />
              </div>
            </div>
            <div class="form-group">
              <label class="field-label">Harga Jual Eceran</label>
              <div class="input-wrap">
                <span class="rp-prefix">Rp</span>
                <input type="text" name="harga_jual_eceran" class="form-control input-with-prefix" value="0" placeholder="0" />
              </div>
            </div>
            <div class="form-group">
              <label class="field-label">Harga Jual Grosir</label>
              <div class="input-wrap">
                <span class="rp-prefix">Rp</span>
                <input type="text" name="harga_jual_grosir" class="form-control input-with-prefix" value="0" placeholder="0" />
              </div>
            </div>
          </div>
        </div>

        <!-- Section 5: Catatan -->
        <div class="form-panel">
          <div class="panel-header">
            <span class="panel-icon">📝</span>
            <span class="panel-title">Catatan Tambahan</span>
          </div>
          <div class="form-group">
            <textarea name="keterangan" class="form-control" rows="2" placeholder="Catatan opsional tentang barang ini..."></textarea>
          </div>
        </div>

        <div class="modal-actions">
          <button type="button" class="btn btn-outline btn-lg" onclick="closeAddModal()">Batal</button>
          <button type="submit" class="btn btn-primary btn-lg" id="submitBtn">
            <span>💾</span> Simpan Barang
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Edit Modal -->
  <div id="editModal" class="modal-overlay hidden">
    <div class="modal add-modal">
      <div class="modal-header">
        <div class="modal-title-wrap">
          <div class="modal-icon">✏️</div>
          <div>
            <h2>Edit Barang</h2>
            <p class="modal-sub" id="editModalSku">-</p>
          </div>
        </div>
        <button class="modal-close" onclick="closeEditModal()">&times;</button>
      </div>

      <form id="editItemForm" onsubmit="return submitEdit(event)">
        <input type="hidden" name="id" id="editItemId" />

        <!-- Section 1: Identitas Barang -->
        <div class="form-panel">
          <div class="panel-header">
            <span class="panel-icon">️</span>
            <span class="panel-title">Identitas Barang</span>
          </div>
          <div class="form-grid">
            <div class="form-group fg-2">
              <label class="field-label">Nama Barang <span class="required">*</span></label>
              <div class="input-wrap">
                <span class="input-icon">📋</span>
                <input type="text" name="nama_barang" id="editNama" class="form-control input-with-icon" required />
              </div>
            </div>
            <div class="form-group">
              <label class="field-label">Merk / Brand</label>
              <div class="input-wrap">
                <span class="input-icon">©️</span>
                <input type="text" name="merk" id="editMerk" class="form-control input-with-icon" />
              </div>
            </div>
            <div class="form-group">
              <label class="field-label">Kategori <span class="required">*</span></label>
              <div class="input-wrap">
                <span class="input-icon">🏗️</span>
                <input type="text" name="kategori" id="editKategori" class="form-control input-with-icon" required list="kategoriList" />
              </div>
            </div>
            <div class="form-group">
              <label class="field-label">Satuan <span class="required">*</span></label>
              <div class="input-wrap">
                <span class="input-icon">⚖️</span>
                <input type="text" name="satuan" id="editSatuan" class="form-control input-with-icon" required list="satuanList" />
              </div>
            </div>
          </div>
        </div>

        <!-- Section 2: Lokasi & Supplier -->
        <div class="form-panel">
          <div class="panel-header">
            <span class="panel-icon">📍</span>
            <span class="panel-title">Lokasi & Supplier</span>
          </div>
          <div class="form-grid cols-2">
            <div class="form-group">
              <label class="field-label">Lokasi Rak / Gudang</label>
              <div class="input-wrap">
                <span class="input-icon">🗺️</span>
                <input type="text" name="lokasi_rak" id="editLokasi" class="form-control input-with-icon" />
              </div>
            </div>
            <div class="form-group">
              <label class="field-label">Supplier Utama</label>
              <div class="input-wrap">
                <span class="input-icon">🚚</span>
                <input type="text" name="supplier" id="editSupplier" class="form-control input-with-icon" />
              </div>
            </div>
          </div>
        </div>

        <!-- Section 3: Stok -->
        <div class="form-panel">
          <div class="panel-header">
            <span class="panel-icon">📊</span>
            <span class="panel-title">Pengaturan Stok</span>
          </div>
          <div class="form-grid cols-3">
            <div class="form-group">
              <label class="field-label">Stok Saat Ini</label>
              <div class="number-stepper">
                <button type="button" class="stepper-btn" onclick="adjustNumber('editStock', -1)">−</button>
                <input type="number" name="stock_saat_ini" id="editStock" class="form-control stepper-input" value="0" min="0" />
                <button type="button" class="stepper-btn" onclick="adjustNumber('editStock', 1)">+</button>
              </div>
            </div>
            <div class="form-group">
              <label class="field-label">Batas Stok Minimum</label>
              <div class="number-stepper">
                <button type="button" class="stepper-btn" onclick="adjustNumber('editMinStock', -1)">−</button>
                <input type="number" name="batas_stok_min" id="editMinStock" class="form-control stepper-input" value="5" min="0" />
                <button type="button" class="stepper-btn" onclick="adjustNumber('editMinStock', 1)">+</button>
              </div>
            </div>
            <div class="form-group stock-info-box">
              <div class="stock-info-content">
                <span class="info-icon">💡</span>
