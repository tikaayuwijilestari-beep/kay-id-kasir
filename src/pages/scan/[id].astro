---
import { getDB, getEnvFromLocals } from '../../lib/db';

export const prerender = false;

const { id } = Astro.params;
const env = getEnvFromLocals(Astro.locals);
const db = await getDB(env);

const item = await db.prepare(`
  SELECT id, sku, nama_barang, merk, kategori, satuan, lokasi_rak, supplier,
         stock_saat_ini, batas_stok_min, harga_beli_awal, harga_jual_eceran,
         harga_jual_grosir, keterangan
  FROM inventory WHERE id = ?
`).bind(id).first() as any;

if (!item) {
  return Astro.redirect('/404');
}

const formatCurrency = (n: number) => new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(n || 0);
const isLow = item.stock_saat_ini <= item.batas_stok_min;
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{item.sku} - {item.nama_barang} | Kay.id</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #f0f2f5;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 16px;
    }
    .card {
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
      max-width: 480px;
      width: 100%;
      overflow: hidden;
    }
    .header {
      background: linear-gradient(135deg, #1a56db 0%, #1e40af 100%);
      color: #fff;
      padding: 24px;
      text-align: center;
    }
    .header .sku {
      font-size: 14px;
      opacity: 0.8;
      letter-spacing: 1px;
      margin-bottom: 4px;
    }
    .header h1 {
      font-size: 22px;
      font-weight: 700;
    }
    .header .location {
      margin-top: 12px;
      background: rgba(255,255,255,0.2);
      display: inline-block;
      padding: 6px 16px;
      border-radius: 20px;
      font-size: 14px;
      font-weight: 600;
    }
    .body { padding: 24px; }
    .info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    .info-item {
      background: #f8f9fa;
      border-radius: 12px;
      padding: 14px;
    }
    .info-item .label {
      font-size: 11px;
      text-transform: uppercase;
      color: #6b7280;
      font-weight: 600;
      letter-spacing: 0.5px;
      margin-bottom: 4px;
    }
    .info-item .value {
      font-size: 18px;
      font-weight: 700;
      color: #111827;
    }
    .info-item .value.small { font-size: 14px; }
    .stock-bar {
      height: 8px;
      background: #e5e7eb;
      border-radius: 4px;
      margin-top: 8px;
      overflow: hidden;
    }
    .stock-bar-fill {
      height: 100%;
      border-radius: 4px;
      transition: width 0.3s;
    }
    .status-badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 12px;
      font-size: 12px;
      font-weight: 700;
      margin-top: 8px;
    }
    .status-ok { background: #d1fae5; color: #065f46; }
    .status-low { background: #fee2e2; color: #991b1b; }
    .footer {
      text-align: center;
      padding: 16px 24px 24px;
      color: #9ca3af;
      font-size: 12px;
    }
    .footer a { color: #1a56db; text-decoration: none; }
  </style>
</head>
<body>
  <div class="card">
    <div class="header">
      <div class="sku">{item.sku}</div>
      <h1>{item.nama_barang}</h1>
      {item.lokasi_rak && <div class="location">📍 Rak {item.lokasi_rak}</div>}
    </div>
    <div class="body">
      <div class="info-grid">
        <div class="info-item">
          <div class="label">Stok Saat Ini</div>
          <div class="value">{item.stock_saat_ini} {item.satuan}</div>
          <div class="stock-bar">
            <div class="stock-bar-fill" style="width: {Math.min((item.stock_saat_ini / Math.max(item.batas_stok_min * 3, 1)) * 100, 100)}%; background: {isLow ? '#ef4444' : '#22c55e'}"></div>
          </div>
          <span class="status-badge {isLow ? 'status-low' : 'status-ok'}">{isLow ? '⚠️ MENIPIS' : '✅ AMAN'}</span>
        </div>
        <div class="info-item">
          <div class="label">Harga Jual Eceran</div>
          <div class="value">{formatCurrency(item.harga_jual_eceran)}</div>
        </div>
        {item.merk && (
          <div class="info-item">
            <div class="label">Merk</div>
            <div class="value small">{item.merk}</div>
          </div>
        )}
        {item.kategori && (
          <div class="info-item">
            <div class="label">Kategori</div>
            <div class="value small">{item.kategori}</div>
          </div>
        )}
        {item.supplier && (
          <div class="info-item">
            <div class="label">Supplier</div>
            <div class="value small">{item.supplier}</div>
          </div>
        )}
        <div class="info-item">
          <div class="label">Min. Stok</div>
          <div class="value small">{item.batas_stok_min} {item.satuan}</div>
        </div>
      </div>
    </div>
    <div class="footer">
      Powered by <a href="/">Kay.id Inventory</a>
    </div>
  </div>
</body>
</html>
